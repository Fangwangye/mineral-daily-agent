# ===== LLM（必填其一）=====
# DeepSeek（默认端点 https://api.deepseek.com，模型 deepseek-chat）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# 或任意 OpenAI 兼容端点（设置后覆盖 DeepSeek 默认值）
#LLM_API_KEY=
#LLM_BASE_URL=https://api.deepseek.com
#LLM_MODEL=deepseek-chat

# ===== 可选 =====
# 1 = 全离线模式：数据源不出网，用打包 fixture/快照（LLM 仍需 key）
#MINERAL_OFFLINE=

# 自定义新闻 RSS 源（逗号分隔，默认 mining.com）
#NEWS_FEEDS=

# 数据缓存目录（默认 ~/.cache/mineral-daily）
#MINERAL_CACHE_DIR=

# 日志级别（默认 INFO）
#LOG_LEVEL=
